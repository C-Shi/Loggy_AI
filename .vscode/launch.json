{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Detector",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/services/loggy_ai/app/main.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/bin/python",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/services/loggy_ai"
            }
        },
        {
            "name": "FastAPI: Dev Server",
            "type": "debugpy",
            "request": "launch",
            "module": "fastapi",
            "args": [
                "dev",
                "main.py"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}/services/loggy_ai/web",
            "console": "integratedTerminal"
        }
    ]
}
